{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tensor-systems/droste/benchmarks/schemas/run-artifact-v1.schema.json",
  "title": "Droste benchmark run artifact v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "suite_id",
    "suite_version",
    "manifest_sha256",
    "benchmark_id",
    "task_id",
    "arm_id",
    "status",
    "metric",
    "score",
    "usage",
    "cost_microusd",
    "wall_time_ms",
    "iterations",
    "subcalls",
    "error",
    "provider",
    "root_model",
    "subcall_model",
    "price_table_version",
    "started_at",
    "droste_commit"
  ],
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "ok" } } },
      "then": {
        "properties": {
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "error": { "const": null }
        }
      },
      "else": {
        "properties": {
          "score": { "type": "null" },
          "error": { "type": "string", "minLength": 1 }
        }
      }
    },
    {
      "if": { "properties": { "cost_microusd": { "minimum": 1 } } },
      "then": {
        "properties": {
          "price_table_version": { "type": "string", "minLength": 1 }
        }
      }
    },
    {
      "oneOf": [
        {
          "required": ["prediction"],
          "properties": {
            "prediction_sha256": { "const": null }
          }
        },
        {
          "required": ["prediction_sha256"],
          "not": { "required": ["prediction"] },
          "properties": {
            "prediction_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        }
      ]
    },
    {
      "oneOf": [
        {
          "required": ["reference"],
          "properties": {
            "reference_sha256": { "const": null }
          }
        },
        {
          "required": ["reference_sha256"],
          "not": { "required": ["reference"] },
          "properties": {
            "reference_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        }
      ]
    }
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "suite_id": { "type": "string", "pattern": "^(?!.*--)[a-z0-9][a-z0-9._-]*$" },
    "suite_version": { "type": "string", "minLength": 1 },
    "manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "benchmark_id": { "type": "string", "pattern": "^(?!.*--)[a-z0-9][a-z0-9._-]*$" },
    "task_id": { "type": "string", "pattern": "^(?!.*--)[a-z0-9][a-z0-9._-]*$" },
    "arm_id": { "type": "string", "pattern": "^(?!.*--)[a-z0-9][a-z0-9._-]*$" },
    "status": {
      "enum": ["ok", "error", "timeout", "context_limit", "refusal"]
    },
    "metric": {
      "enum": [
        "exact_match",
        "numeric",
        "token_f1",
        "oolong_official",
        "oolong_pairs_f1"
      ]
    },
    "score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "prediction": true,
    "reference": true,
    "prediction_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "reference_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root_input_tokens",
        "root_output_tokens",
        "subcall_input_tokens",
        "subcall_output_tokens",
        "total_tokens"
      ],
      "properties": {
        "root_input_tokens": { "type": "integer", "minimum": 0 },
        "root_output_tokens": { "type": "integer", "minimum": 0 },
        "subcall_input_tokens": { "type": "integer", "minimum": 0 },
        "subcall_output_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 }
      }
    },
    "cost_microusd": { "type": "integer", "minimum": 0 },
    "wall_time_ms": { "type": "integer", "minimum": 0 },
    "iterations": { "type": "integer", "minimum": 0 },
    "subcalls": { "type": "integer", "minimum": 0 },
    "error": { "type": ["string", "null"] },
    "provider": { "type": ["string", "null"] },
    "root_model": { "type": ["string", "null"] },
    "subcall_model": { "type": ["string", "null"] },
    "price_table_version": { "type": ["string", "null"] },
    "started_at": { "type": ["string", "null"], "format": "date-time" },
    "droste_commit": { "type": "string", "minLength": 1 }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tensor-systems/droste/benchmarks/schemas/suite-manifest-v1.schema.json",
  "title": "Droste benchmark suite manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "suite_id",
    "suite_version",
    "live_run",
    "benchmarks",
    "arms"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "suite_id": { "type": "string", "pattern": "^(?!.*--)[a-z0-9][a-z0-9._-]*$" },
    "suite_version": { "type": "string", "minLength": 1 },
    "paper": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "revision", "url"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "revision": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 }
      }
    },
    "live_run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "blockers"],
      "allOf": [
        {
          "if": { "properties": { "enabled": { "const": true } } },
          "then": { "properties": { "blockers": { "maxItems": 0 } } },
          "else": { "properties": { "blockers": { "minItems": 1 } } }
        }
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "blockers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["issue", "reason"],
            "properties": {
              "issue": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "benchmarks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "allOf": [
          {
            "if": { "properties": { "status": { "const": "ready" } } },
            "then": { "required": ["tasks_path"] }
          }
        ],
        "required": [
          "id",
          "dataset",
          "dataset_version",
          "split",
          "scorer",
          "phase",
          "status"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^(?!.*--)[a-z0-9][a-z0-9._-]*$" },
          "dataset": { "type": "string", "minLength": 1 },
          "dataset_version": { "type": "string", "minLength": 1 },
          "split": { "type": "string", "minLength": 1 },
          "scorer": {
            "enum": ["exact_match", "numeric", "token_f1", "oolong_official"]
          },
          "tasks_path": { "type": "string", "minLength": 1 },
          "phase": { "type": "integer", "minimum": 1 },
          "status": { "enum": ["ready", "planned"] }
        }
      }
    },
    "arms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "method", "executor"],
        "allOf": [
          {
            "if": { "properties": { "executor": { "const": "fixture" } } },
            "then": {
              "required": ["predictions_path"],
              "properties": {
                "blocker": false,
                "model": false,
                "limits": false
              }
            },
            "else": {
              "required": ["blocker", "model", "limits"],
              "properties": { "predictions_path": false }
            }
          }
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^(?!.*--)[a-z0-9][a-z0-9._-]*$" },
          "method": { "type": "string", "minLength": 1 },
          "executor": { "enum": ["fixture", "blocked"] },
          "predictions_path": { "type": "string", "minLength": 1 },
          "blocker": { "type": "string", "minLength": 1 },
          "model": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "provider",
              "root_model",
              "subcall_model",
              "root_reasoning_effort",
              "subcall_reasoning_effort",
              "temperature",
              "max_root_output_tokens",
              "max_subcall_output_tokens"
            ],
            "properties": {
              "provider": { "type": "string", "minLength": 1 },
              "root_model": { "type": "string", "minLength": 1 },
              "subcall_model": { "type": ["string", "null"] },
              "root_reasoning_effort": { "type": ["string", "null"] },
              "subcall_reasoning_effort": { "type": ["string", "null"] },
              "temperature": { "type": ["number", "null"] },
              "max_root_output_tokens": { "type": "integer", "minimum": 1 },
              "max_subcall_output_tokens": { "type": ["integer", "null"], "minimum": 1 }
            }
          },
          "limits": {
            "type": "object",
            "additionalProperties": false,
            "required": ["max_iterations", "max_subcalls", "timeout_seconds", "concurrency"],
            "properties": {
              "max_iterations": { "type": "integer", "minimum": 1 },
              "max_subcalls": { "type": "integer", "minimum": 0 },
              "timeout_seconds": { "type": "integer", "minimum": 1 },
              "concurrency": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    }
  }
}
